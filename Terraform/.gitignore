############################################
# Terraform
############################################

# Terraform working directory
**/.terraform/

# Terraform state files
**/*.tfstate
**/*.tfstate.*

# Crash logs
**/crash.log

# Terraform variable files (contains secrets)
**/terraform.tfvars
**/*.auto.tfvars

# Override files
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Terraform plan files
**/*.tfplan

# CLI configuration
.terraformrc
terraform.rc

# Keep lock files
!**/.terraform.lock.hcl

############################################
# IDE
############################################

.vscode/
.idea/

############################################
# Operating System
############################################

.DS_Store
Thumbs.db